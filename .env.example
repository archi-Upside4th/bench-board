# Postgres connection (Neon, Supabase, local docker, etc.)
DATABASE_URL=postgresql://user:password@host:5432/bench_board

# NextAuth v5
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# GitHub OAuth app
# Create at: https://github.com/settings/developers
# Callback URL: http://localhost:3000/api/auth/callback/github
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Comma-separated list of GitHub usernames allowed into /admin
ADMIN_GITHUB_LOGINS=your-github-username
